  "license": "MIT",
  "scripts": {
    "build": "rm -rf ./dist/ && npx tsc",
    "start": "cross-env NODE_ENV=production node ./dist/index.js",
    "dev": "cross-env NODE_ENV=development ts-node ./src/index.ts",
    "watch": "cross-env NODE_ENV=development ts-node-dev --respawn",
    "dev:build-logos": "cross-env NODE_ENV=development ts-node ./src/scripts/build-base64-img-json.ts",
    "run:test-tweet": "cross-env NODE_ENV=development ts-node ./src/scripts/post-test-tweet.ts"
  },
  "dependencies": {
    "@sentry/node": "^6.18.2",
    "@sentry/tracing": "^6.18.2",
    "@twurple/api": "^7.0.0",
    "@twurple/auth": "^7.0.0",
    "@twurple/chat": "^7.0.0",
    "@types/tmi.js": "^1.8.1",
    "@types/utf8": "^3.0.1",
    "dayjs": "^1.10.8",
    "dotenv": "^16.0.0",
    "mongoose": "^6.2.4",
    "puppeteer": "^13.5.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "styled-components": "^5.3.3",
    "tmi.js": "^1.8.5",
    "twitter-api-v2": "^1.11.0",
    "utf8": "^3.0.0",
    "winston": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^17.0.19",
    "@types/react": "^17.0.40",
    "@types/react-dom": "^17.0.13",
    "@types/styled-components": "^5.1.24",
    "cross-env": "^7.0.3",
    "prettier": "^2.5.1",
    "ts-node": "^10.5.0",
    "ts-node-dev": "^1.1.8",
    "typescript": "^4.5.5"
  }
}